@model IEnumerable<Roles>
@{
    ViewData["Title"] = "Roller";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Roller</h1>
        <p class="text-muted mb-0">Sistem rol tanimlari.</p>
    </div>
    @if (User.IsInRole("SuperAdmin"))
    {
        <a class="btn btn-success" asp-action="Create">Yeni rol</a>
    }
</div>

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-info">@TempData["Mesaj"]</div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Rol</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.ad</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Bu rol silinsin mi?');">Sil</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="3"><div class="empty-state">Henuz rol kaydi yok.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
