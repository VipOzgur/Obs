@model IEnumerable<Departmans>
@{
    ViewData["Title"] = "Departmanlar";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Departmanlar</h1>
        <p class="text-muted mb-0">Fakultelere bagli departman kayitlari.</p>
    </div>
    @if (User.IsInRole("SuperAdmin"))
    {
        <a class="btn btn-success" asp-action="Create">Yeni departman</a>
    }
</div>

@foreach (var key in new[] { "Mesaj", "SuccessMessage", "Bilgi", "BilgiMesaji", "Durum", "Hata" })
{
    if (TempData[key] != null)
    {
        <div class="alert alert-info">@TempData[key]</div>
    }
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Departman</th>
                    <th>Fakulte Id</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.ad</td>
                        <td>@item.fakulteId</td>
                        <td class="text-end">
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Bu departman silinsin mi?');">Sil</a>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4"><div class="empty-state">Henuz departman kaydi yok.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
