@model IEnumerable<OgrenciDersNotlariVM>
@{
    var ilkKayit = Model?.FirstOrDefault();
    ViewData["Title"] = "Not Detayi";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Not Detayi</h1>
        <p class="text-muted mb-0">@(ilkKayit == null ? "Ogrenci notlari" : $"{ilkKayit.OgrenciAd} {ilkKayit.OgrenciSoyad}")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Tum notlar</a>
</div>

@if (ilkKayit != null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="surface h-100">
                <div class="surface-body">
                    <div class="text-muted small">Ogrenci Id</div>
                    <div class="h5 mb-0">@ilkKayit.OgrenciId</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="surface h-100">
                <div class="surface-body">
                    <div class="text-muted small">Kayit tarihi</div>
                    <div class="h5 mb-0">@ilkKayit.KayitTarihi.ToString("dd.MM.yyyy")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="surface h-100">
                <div class="surface-body">
                    <div class="text-muted small">Mezuniyet</div>
                    <div class="h5 mb-0">@(ilkKayit.MezunTarihi?.ToString("dd.MM.yyyy") ?? "-")</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Ders</th>
                    <th>Sinif</th>
                    <th>Donem</th>
                    <th>AKTS</th>
                    <th>Puan</th>
                    <th>Harf</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.DersAd</td>
                        <td>@item.SinifAd</td>
                        <td>@item.Donem</td>
                        <td>@item.Akts</td>
                        <td>@item.Puan</td>
                        <td><span class="badge text-bg-secondary">@item.HarfNotu</span></td>
                        <td><span class="badge @(item.Basari ? "text-bg-success" : "text-bg-danger")">@item.DurumAd</span></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7"><div class="empty-state">Detay kaydi bulunamadi.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
