@model IEnumerable<PersonelDetayVM>
@{
    ViewData["Title"] = "Personel Detay";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Personel Detay</h1>
        <p class="text-muted mb-0">Personel, rol, departman ve fakulte bilgileri.</p>
    </div>
    <form asp-action="Filtrele" method="get" class="d-flex gap-2">
        <input class="form-control" name="departmanAdi" placeholder="Departman adi" />
        <button class="btn btn-success" type="submit">Filtrele</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Temizle</a>
    </form>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Personel</th>
                    <th>Rol</th>
                    <th>Departman</th>
                    <th>Fakulte</th>
                    <th>Adres</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@(string.IsNullOrWhiteSpace(item.TamAd) ? $"{item.PersonelAd} {item.PersonelSoyad}" : item.TamAd)</div>
                            <div class="text-muted small">Id: @item.PersonelId</div>
                        </td>
                        <td>@item.RoleAd</td>
                        <td>@item.DepartmanAd</td>
                        <td>
                            <div>@item.FakulteAd</div>
                            <div class="text-muted small">@item.FakulteKurulusTarihi.ToString("dd.MM.yyyy")</div>
                        </td>
                        <td>@item.PersonelAdres</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5"><div class="empty-state">Personel detay kaydi bulunamadi.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
