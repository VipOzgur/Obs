@model IEnumerable<Ogrenci>
@{
    ViewData["Title"] = "Ogrenciler";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Ogrenciler</h1>
        <p class="text-muted mb-0">Ogrenci hesap ve kayit bilgileri.</p>
    </div>
    @if (User.IsInRole("SuperAdmin"))
    {
        <a class="btn btn-success" asp-action="Create">Yeni ogrenci</a>
    }
</div>

@if (TempData["BilgiMesaji"] != null)
{
    <div class="alert alert-info">@TempData["BilgiMesaji"]</div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Ad soyad</th>
                    <th>Role Id</th>
                    <th>Kayit tarihi</th>
                    <th>Mezuniyet</th>
                    <th>Adres</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.ad @item.soyad</td>
                        <td>@item.roleId</td>
                        <td>@item.kayitTarihi.ToString("dd.MM.yyyy")</td>
                        <td>@(item.mezunTarihi?.ToString("dd.MM.yyyy") ?? "-")</td>
                        <td>@item.adres</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="OgrenciDersNotlari" asp-action="Detay" asp-route-ogrenciId="@item.Id">Notlar</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="DersSecim" asp-action="Index" asp-route-ogrenciId="@item.Id">Dersler</a>
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Bu ogrenci silinsin mi?');">Sil</a>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7"><div class="empty-state">Henuz ogrenci kaydi yok.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
