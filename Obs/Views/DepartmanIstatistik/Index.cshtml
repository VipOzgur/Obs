@model IEnumerable<DepartmanIstatistikVM>
@{
    ViewData["Title"] = "Departman Istatistikleri";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Departman Istatistikleri</h1>
        <p class="text-muted mb-0">Departman bazinda personel, ders ve AKTS ozeti.</p>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="surface h-100">
            <div class="surface-body">
                <div class="text-muted small">Departman</div>
                <div class="h4 mb-0">@(Model?.Count() ?? 0)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="surface h-100">
            <div class="surface-body">
                <div class="text-muted small">Toplam personel</div>
                <div class="h4 mb-0">@(Model?.Sum(x => x.PersonelSayisi) ?? 0)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="surface h-100">
            <div class="surface-body">
                <div class="text-muted small">Toplam AKTS</div>
                <div class="h4 mb-0">@(Model?.Sum(x => x.ToplamAkts) ?? 0)</div>
            </div>
        </div>
    </div>
</div>

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Fakulte</th>
                    <th>Departman</th>
                    <th>Personel</th>
                    <th>Ders</th>
                    <th>AKTS</th>
                    <th>Profesor</th>
                    <th>Docent</th>
                    <th>Arastirmaci</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FakulteAd</td>
                        <td class="fw-semibold">@item.DepartmanAd</td>
                        <td>@item.PersonelSayisi</td>
                        <td>@item.DersSayisi</td>
                        <td>@item.ToplamAkts</td>
                        <td>@item.ProfesorSayisi</td>
                        <td>@item.DocentSayisi</td>
                        <td>@item.ArastirmaciSayisi</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="8"><div class="empty-state">Istatistik kaydi bulunamadi.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
