@model Siniflar
@{
    ViewData["Title"] = "Yeni Sinif";
}

<div class="page-heading">
    <h1 class="h3 mb-0">Yeni Sinif</h1>
    <a class="btn btn-outline-secondary" asp-action="Index">Listeye don</a>
</div>

<div class="surface">
    <form asp-action="Create" method="post" class="surface-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-5">
                <label asp-for="ad" class="form-label">Sinif adi</label>
                <input asp-for="ad" class="form-control" />
                <span asp-validation-for="ad" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="no" class="form-label">No</label>
                <input asp-for="no" class="form-control" />
                <span asp-validation-for="no" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="fakulteId" class="form-label">Fakulte Id</label>
                <input asp-for="fakulteId" class="form-control" type="number" min="1" />
                <span asp-validation-for="fakulteId" class="text-danger"></span>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-success">Kaydet</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Vazgec</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
