@model IEnumerable<Siniflar>
@{
    ViewData["Title"] = "Siniflar";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Siniflar</h1>
        <p class="text-muted mb-0">Sinif, numara ve fakulte eslesmeleri.</p>
    </div>
    @if (User.IsInRole("SuperAdmin"))
    {
        <a class="btn btn-success" asp-action="Create">Yeni sinif</a>
    }
</div>

@if (TempData["Bilgi"] != null)
{
    <div class="alert alert-info">@TempData["Bilgi"]</div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Sinif</th>
                    <th>No</th>
                    <th>Fakulte Id</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.ad</td>
                        <td>@item.no</td>
                        <td>@item.fakulteId</td>
                        <td class="text-end">
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Bu sinif silinsin mi?');">Sil</a>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5"><div class="empty-state">Henuz sinif kaydi yok.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
