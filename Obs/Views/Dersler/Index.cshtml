@model IEnumerable<Dersler>
@{
    ViewData["Title"] = "Dersler";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Dersler</h1>
        <p class="text-muted mb-0">Ders kayitlari sp_Ders_Listele uzerinden listelenir.</p>
    </div>
    <a class="btn btn-success" asp-action="Create">Yeni ders</a>
</div>

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-info">@TempData["Mesaj"]</div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Ders</th>
                    <th>AKTS</th>
                    <th>Donem</th>
                    <th>Personel Id</th>
                    <th>Sinif Id</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.ad</td>
                        <td>@item.akts</td>
                        <td>@item.donem</td>
                        <td>@item.personelId</td>
                        <td>@item.sinifId</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                            <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Bu ders silinsin mi?');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7"><div class="empty-state">Henuz ders kaydi yok.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
