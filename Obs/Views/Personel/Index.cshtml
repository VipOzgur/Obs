@model IEnumerable<Personel>
@{
    ViewData["Title"] = "Personel";
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Personel</h1>
        <p class="text-muted mb-0">Personel temel bilgileri.</p>
    </div>
    @if (User.IsInRole("SuperAdmin"))
    {
        <a class="btn btn-success" asp-action="Create">Yeni personel</a>
    }
</div>

@if (TempData["Durum"] != null)
{
    <div class="alert alert-info">@TempData["Durum"]</div>
}

<div class="surface">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Ad soyad</th>
                    <th>Role Id</th>
                    <th>Departman Id</th>
                    <th>Adres</th>
                    <th class="text-end">Islemler</th>
                </tr>
            </thead>
            <tbody>
            @if (Model?.Any() == true)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-semibold">@item.ad @item.soyad</td>
                        <td>@item.roleId</td>
                        <td>@item.departmanId</td>
                        <td>@item.adres</td>
                        <td class="text-end">
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Duzenle</a>
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Bu personel silinsin mi?');">Sil</a>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6"><div class="empty-state">Henuz personel kaydi yok.</div></td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
